<%- include('../partials/nav') %>

    <h1>Edit a Book</h1>

    <form action="/books/<%= foundBook._id %>?_method=PUT" method="POST" class="book-form">
        <div class="form-group">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" value="<%= foundBook.title %>">
        </div>

        <div class="form-group">
            <label for="author">Author</label>
            <input type="text" id="author" name="author" value="<%= foundBook.author %>">
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description"><%= foundBook.description %></textarea>
        </div>

        <div class="form-group">
            <label for="image">Image URL</label>
            <input type="text" id="image" name="image" value="<%= foundBook.image %>">
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="status">Status</label>
                <select id="status" name="status">
                    <option value="Want to Read" <%= foundBook.status === 'Want to Read' ? 'selected' : '' %>>Want to Read</option>
                    <option value="Currently Reading" <%= foundBook.status === 'Currently Reading' ? 'selected' : '' %>>Currently Reading</option>
                    <option value="Read" <%= foundBook.status === 'Read' ? 'selected' : '' %>>Read</option>
                    <option value="DNF" <%= foundBook.status === 'DNF' ? 'selected' : '' %>>DNF</option>
                </select>
            </div>

            <div class="form-group">
                <label for="ownershipStatus">Ownership Status</label>
                <select id="ownershipStatus" name="ownershipStatus">
                    <option value="Owned" <%= foundBook.ownershipStatus === 'Owned' ? 'selected' : '' %>>Owned</option>
                    <option value="Want to Buy" <%= foundBook.ownershipStatus === 'Want to Buy' ? 'selected' : '' %>>Want to Buy</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label for="rate">Rate</label>
            <input type="number" id="rate" name="rate" value="<%= foundBook.rate %>" min="1" max="5">
        </div>

        <div class="form-group">
            <label for="review">Review</label>
            <textarea id="review" name="review" maxlength="400"><%= foundBook.review %></textarea>
        </div>

        <div class="form-group">
            <label for="genres">Genres</label>
            <select id="genres" name="genres" multiple size="6">
                <option value="Fiction" <%= foundBook.genres.includes('Fiction') ? 'selected' : '' %>>Fiction</option>
                <option value="Nonfiction" <%= foundBook.genres.includes('Nonfiction') ? 'selected' : '' %>>Nonfiction</option>
                <option value="Memoir" <%= foundBook.genres.includes('Memoir') ? 'selected' : '' %>>Memoir</option>
                <option value="Biography" <%= foundBook.genres.includes('Biography') ? 'selected' : '' %>>Biography</option>
                <option value="Fantasy" <%= foundBook.genres.includes('Fantasy') ? 'selected' : '' %>>Fantasy</option>
                <option value="Science Fiction" <%= foundBook.genres.includes('Science Fiction') ? 'selected' : '' %>>Science Fiction</option>
                <option value="Mystery" <%= foundBook.genres.includes('Mystery') ? 'selected' : '' %>>Mystery</option>
                <option value="Thriller" <%= foundBook.genres.includes('Thriller') ? 'selected' : '' %>>Thriller</option>
                <option value="Romance" <%= foundBook.genres.includes('Romance') ? 'selected' : '' %>>Romance</option>
                <option value="Historical Fiction" <%= foundBook.genres.includes('Historical Fiction') ? 'selected' : '' %>>Historical Fiction</option>
                <option value="Self-Help" <%= foundBook.genres.includes('Self-Help') ? 'selected' : '' %>>Self-Help</option>
                <option value="Poetry" <%= foundBook.genres.includes('Poetry') ? 'selected' : '' %>>Poetry</option>
                <option value="Young Adult" <%= foundBook.genres.includes('Young Adult') ? 'selected' : '' %>>Young Adult</option>
                <option value="Children's" <%= foundBook.genres.includes("Children's") ? 'selected' : '' %>>Children's</option>
                <option value="Horror" <%= foundBook.genres.includes('Horror') ? 'selected' : '' %>>Horror</option>
                <option value="Classics" <%= foundBook.genres.includes('Classics') ? 'selected' : '' %>>Classics</option>
            </select>
        </div>

        <div class="form-group checkbox-group">
            <label for="isBorrowable">Is Borrowable?</label>
            <% if (foundBook.isBorrowable) { %>
                <input type="checkbox" id="isBorrowable" name="isBorrowable" checked>
            <% } else { %>
                <input type="checkbox" id="isBorrowable" name="isBorrowable">
            <% } %>
        </div>

        <button type="submit" class="submit-btn">Submit</button>
    </form>

</body>
</html>