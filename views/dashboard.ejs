<%- include('./partials/nav') %>


    <h1><%= user.username %>'s Pending Requests</h1>
    <% borrowRequest.forEach((item) => { %>
        <p><%= item.userId.username  %> <%= `${item.requestDate.toDateString()} at ${item.requestDate.getHours()}: ${item.requestDate.getMinutes()}`  %> <%= item.bookId.title %>
            <form action="/dashboard/<%= item._id %>?_method=PUT" method="POST">
                <button type="submit">Accept</button> 
            </form>
            <form action="/dashboard?_method=PUT" method="POST">
                <button type="submit">Reject</button>
            </form>
        </p>
    <% }) %>

</body>
</html>